<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- ============================================================
       SIGNATURE AUTO ADD-IN - OUTLOOK
       À personnaliser : remplacer VOTRE_DOMAINE.COM par votre domaine
       et mettre à jour les URLs d'hébergement des fichiers HTML/JS
       ============================================================ -->

  <Id>f7a3b921-4d8e-4c6f-b205-9e1d73a82c54</Id>
  <!-- Générer un nouveau GUID unique via : [System.Guid]::NewGuid() en PowerShell -->

  <Version>1.0.0.0</Version>
  <ProviderName>Solutions D'affaires STO</ProviderName>
  <DefaultLocale>fr-CA</DefaultLocale>

  <DisplayName DefaultValue="Signature Automatique"/>
  <Description DefaultValue="Insère automatiquement la signature depuis le profil Microsoft 365"/>

  <IconUrl DefaultValue="https://abdelkb.github.io/signature-m365/addin/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://abdelkb.github.io/signature-m365/addin/assets/icon-128.png"/>
  <SupportUrl DefaultValue="https://abdelkb.github.io/signature-m365"/>

  <AppDomains>
    <AppDomain>https://abdelkb.github.io/signature-m365</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <!-- Mode lecture (optionnel - désactivé si non voulu) -->
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://abdelkb.github.io/signature-m365/addin/signature.html"/>
        <RequestedHeight>0</RequestedHeight>
      </DesktopSettings>
    </Form>
    <!-- Composition : nouveaux emails ET réponses/transferts -->
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://abdelkb.github.io/signature-m365/addin/signature.html"/>
        <RequestedHeight>0</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <!-- Déclenché à la composition d'un nouveau message -->
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url"/>

          <!-- Événement OnMessageCompose : nouveaux emails -->
          <ExtensionPoint xsi:type="Events">
            <Event Type="OnMessageCompose" FunctionExecution="async" FunctionName="insertSignatureOnCompose"/>
            <!-- Événement OnMessageReply : réponses et transferts -->
            <Event Type="OnMessageReply" FunctionExecution="async" FunctionName="insertSignatureOnReply"/>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://VOTRE_DOMAINE.COM/addin/commands.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Signature"/>
      </bt:ShortStrings>
    </Resources>
  </VersionOverrides>

</OfficeApp>
