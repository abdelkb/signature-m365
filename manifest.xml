<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="MailApp">

  <Id>f7a3b921-4d8e-4c6f-b205-9e1d73a82c54</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Solutions D'affaires STO</ProviderName>
  <DefaultLocale>fr-CA</DefaultLocale>
  <DisplayName DefaultValue="Signature Automatique"/>
  <Description DefaultValue="Insere automatiquement la signature depuis le profil Microsoft 365"/>
  <IconUrl DefaultValue="https://abdelkb.github.io/signature-m365/addin/assets/icon-64.svg"/>
  <HighResolutionIconUrl DefaultValue="https://abdelkb.github.io/signature-m365/addin/assets/icon-64.svg"/>
  <SupportUrl DefaultValue="https://abdelkb.github.io/signature-m365"/>

  <AppDomains>
    <AppDomain>https://abdelkb.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://abdelkb.github.io/signature-m365/addin/commands.html"/>
        <RequestedHeight>0</RequestedHeight>
      </DesktopSettings>
    </Form>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://abdelkb.github.io/signature-m365/addin/commands.html"/>
        <RequestedHeight>0</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="Events">
            <Event Type="OnMessageCompose" FunctionExecution="async" FunctionName="insertSignatureOnCompose"/>
            <Event Type="OnMessageReply" FunctionExecution="async" FunctionName="insertSignatureOnReply"/>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://abdelkb.github.io/signature-m365/addin/commands.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Signature"/>
      </bt:ShortStrings>
    </Resources>
  </VersionOverrides>

</OfficeApp>
